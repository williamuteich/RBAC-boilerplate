generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Administrator {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  email     String    @unique
  name      String?
  password  String?
  image     String?
  active    Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  roleId    String?   @db.ObjectId
  role      AdminRole? @relation(fields: [roleId], references: [id])
  logAdmins LogAdmin[]
}

model AdminRole {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  administrators Administrator[]
  permissions    AdminRolePermission[]
}

model AdminPermission {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  resource    String
  action      String
  description String?

  roles AdminRolePermission[]

  @@unique([resource, action])
}

model AdminRolePermission {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  adminRoleId       String   @db.ObjectId
  adminPermissionId String   @db.ObjectId
  createdAt         DateTime @default(now())

  role       AdminRole       @relation(fields: [adminRoleId], references: [id], onDelete: Cascade)
  permission AdminPermission @relation(fields: [adminPermissionId], references: [id], onDelete: Cascade)

  @@unique([adminRoleId, adminPermissionId])
}

model LogAdmin {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  administratorId String        @db.ObjectId
  administrator   Administrator @relation(fields: [administratorId], references: [id], onDelete: Cascade)

  action       String
  resource     String?
  resourceId   String?
  resourceName String?

  url String?

  createdAt DateTime @default(now())
}
