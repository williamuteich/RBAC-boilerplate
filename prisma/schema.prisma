generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Administrator {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  password  String?
  image     String?
  active    Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  roleId    Int?
  role      AdminRole? @relation(fields: [roleId], references: [id])
  logAdmins LogAdmin[]
}

model AdminRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  administrators Administrator[]
}

model LogAdmin {
  id Int @id @default(autoincrement())

  administratorId Int
  administrator   Administrator @relation(fields: [administratorId], references: [id], onDelete: Cascade)

  action       AdminActionType
  resource     String?
  resourceId   String?
  resourceName String?

  url String?

  createdAt DateTime @default(now())
}

enum AdminActionType {
  CREATE
  UPDATE
  DELETE
}

model SaaSClient {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  name             String
  image            String?
  tributeId        String    @unique @default(uuid())
  status           String    @default("ACTIVE")
  plan             String    @default("MONTHLY")
  lastPaymentValue Float?
  lastPaymentDate  DateTime?
  expirationDate   DateTime?
  photosCount      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  partnerA    String @default("Lucas")
  partnerB    String @default("Gabriela")
  anniversary String @default("12/06/2023")
  theme       String @default("spotify")
  songTitle   String @default("Perfect")
  songArtist  String @default("Ed Sheeran")
  songUrl     String @default("https://www.youtube.com/watch?v=yKNxeF4Kxyc")
  letterTitle String @default("Para Minha Vida,")
  letterBody  String @default("Desde o momento em que te conheci, percebi que minha vida nunca mais seria a mesma. Cada detalhe, cada conversa e cada sorriso ao seu lado me fazem ter a certeza de que quero passar o resto dos meus dias com você.")
  photos      Json   @default("[]")
}

model Coupon {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  expiresAt    DateTime?
  durationDays Int       @default(7)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
